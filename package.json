{
	"name": "project-kelsier",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.28.2",
	"engines": {
		"node": "24.x"
	},
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "pnpm build && vite preview",
		"deploy": "pnpm build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"coverage": "vitest run --config vitest.config.ts --coverage",
		"test:e2e": "playwright test",
		"ci": "pnpm check && pnpm typecheck && pnpm test && pnpm build"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-devtools": "0.10.2",
		"@tanstack/react-router": "1.168.24",
		"@tanstack/react-router-devtools": "1.166.13",
		"@tanstack/react-router-ssr-query": "1.166.12",
		"@tanstack/react-start": "1.167.49",
		"@tanstack/router-plugin": "^1.167.27",
		"lucide-react": "^1.11.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwindcss": "^4.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@cloudflare/vite-plugin": "^1.33.2",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tanstack/devtools-vite": "0.6.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"@vitest/coverage-v8": "^3.2.4",
		"jsdom": "^28.1.0",
		"typescript": "^6.0.3",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4",
		"wrangler": "^4.85.0"
	}
}
